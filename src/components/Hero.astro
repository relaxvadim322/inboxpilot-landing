---
const channels = ['Telegram', 'Instagram', 'Форма на сайте', 'Google Sheets', 'CRM-ready'];
---

<section class="hero section">
  <!-- Subtle background glow -->
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container hero-inner">
    <!-- Left: copy -->
    <div class="hero-copy">
      <div class="badge anim">AI-ассистент для входящих заявок</div>

      <h1 class="hero-h1 anim">
        AI-ассистент, который не даёт заявкам теряться в&nbsp;переписках
      </h1>

      <p class="hero-sub anim">
        Настроим AI-ассистента за 7&nbsp;дней: он отвечает на частые вопросы, собирает данные клиента и передаёт горячие обращения в Telegram, таблицу или простой CRM-процесс.
      </p>

      <div class="hero-ctas anim">
        <a href="#final-cta" class="btn btn-primary btn-lg">Получить разбор входящих заявок</a>
        <a href="#how-it-works" class="btn btn-ghost btn-lg">Посмотреть механику</a>
      </div>

      <p class="hero-microcopy anim">
        Без сложной CRM, долгой разработки и «AI-магии». Сначала разбираем ваши реальные переписки, потом собираем рабочий сценарий.
      </p>
    </div>

    <!-- Right: chat mockup -->
    <div class="hero-visual anim">
      <div class="chat-card">
        <!-- Chat header -->
        <div class="chat-header">
          <div class="chat-avatar" aria-hidden="true">IP</div>
          <div class="chat-meta">
            <span class="chat-name">InboxPilot</span>
            <span class="chat-online">
              <span class="chat-online-dot" aria-hidden="true"></span>
              онлайн
            </span>
          </div>
        </div>

        <!-- Messages -->
        <div class="chat-messages" role="log" aria-label="Пример диалога">
          <div class="msg msg-client">
            <div class="msg-bubble">
              Здравствуйте, сколько стоит консультация и когда можно записаться?
            </div>
            <span class="msg-time">14:32</span>
          </div>

          <div class="msg msg-ai">
            <div class="msg-bubble">
              Добрый день! Консультация стоит от 900 грн. Подскажите, пожалуйста, какая услуга вас интересует и на какой день вам удобно?
            </div>
            <span class="msg-time">14:32</span>
          </div>

          <div class="msg msg-client">
            <div class="msg-bubble">
              Маникюр, лучше пятница после 16:00.
            </div>
            <span class="msg-time">14:33</span>
          </div>

          <div class="msg msg-ai">
            <div class="msg-bubble">
              Принял. Передаю заявку администратору. Он подтвердит свободное время и свободные окна.
            </div>
            <span class="msg-time">14:33</span>
          </div>

          <!-- Typing indicator -->
          <div class="msg msg-ai msg-typing" aria-label="Ассистент печатает">
            <div class="typing-dots" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
        </div>

        <!-- Channel tags -->
        <div class="chat-channels">
          {channels.map((ch) => (
            <span class="tag">{ch}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -180px;
    right: -100px;
    width: 680px;
    height: 680px;
    background: radial-gradient(circle, rgba(79, 140, 255, 0.17) 0%, transparent 68%);
    pointer-events: none;
    user-select: none;
    animation: breatheGlow 9s ease-in-out infinite;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  /* ── Copy ── */
  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .hero-h1 {
    margin: 0;
  }

  .hero-sub {
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 52ch;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero-microcopy {
    font-size: var(--text-sm);
    color: var(--text-muted);
    opacity: 0.75;
  }

  /* ── Chat card ── */
  .chat-card {
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-chat);
    overflow: hidden;
    animation: floatY 7s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .chat-card { animation: none; }
  }

  .chat-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border);
    background: var(--surface-2);
  }

  .chat-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--accent-blue);
    color: #fff;
    font-size: var(--text-xs);
    font-weight: 700;
    flex-shrink: 0;
  }

  .chat-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .chat-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text);
  }

  .chat-online {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--accent-green);
  }

  .chat-online-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-green);
    flex-shrink: 0;
  }

  /* ── Messages ── */
  .chat-messages {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    min-height: 260px;
  }

  .msg {
    display: flex;
    flex-direction: column;
    max-width: 80%;
  }

  .msg-client {
    align-self: flex-end;
    align-items: flex-end;
  }

  .msg-ai {
    align-self: flex-start;
    align-items: flex-start;
  }

  .msg-bubble {
    padding: 10px 14px;
    border-radius: 14px;
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .msg-client .msg-bubble {
    background: rgba(79, 140, 255, 0.2);
    border: 1px solid rgba(79, 140, 255, 0.25);
    border-bottom-right-radius: 4px;
    color: var(--text);
  }

  .msg-ai .msg-bubble {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-bottom-left-radius: 4px;
    color: var(--text);
  }

  .msg-time {
    font-size: 10px;
    color: var(--text-muted);
    opacity: 0.6;
    margin-top: 4px;
    padding-inline: 2px;
  }

  /* ── Typing indicator ── */
  .msg-typing {
    align-self: flex-start;
  }

  .typing-dots {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 12px 16px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    border-bottom-left-radius: 4px;
  }

  .typing-dots span {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-muted);
    animation: typingDot 1.5s ease-in-out infinite;
  }

  .typing-dots span:nth-child(2) { animation-delay: 0.22s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.44s; }

  /* ── Channel tags ── */
  .chat-channels {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5);
    border-top: 1px solid var(--border);
    background: var(--surface-2);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }

    .hero-visual {
      max-width: 560px;
      margin-inline: auto;
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .hero-ctas {
      flex-direction: column;
    }

    .hero-ctas .btn {
      width: 100%;
      text-align: center;
    }

    .hero-glow {
      display: none;
    }
  }
</style>
