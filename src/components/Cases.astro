---
const cases = [
  {
    category: 'Студия красоты',
    situation: 'Клиенты часто спрашивают про цену, свободные окна, адрес, мастера и запись.',
    action: 'Уточняет услугу, желаемую дату, время, имя клиента и передаёт заявку администратору.',
    result: 'Администратор получает не просто «сколько стоит?», а уже собранную заявку: услуга, день, время, контакт.',
  },
  {
    category: 'Онлайн-школа',
    situation: 'Люди спрашивают про программу, старт потока, оплату, рассрочку и формат обучения.',
    action: 'Отвечает на базовые вопросы, уточняет интересующий курс и передаёт тёплого лида менеджеру.',
    result: 'Менеджер не тратит время на одинаковые объяснения и быстрее видит заинтересованных людей.',
  },
  {
    category: 'Консультационный эксперт',
    situation: 'В личку приходят разные сообщения: вопросы, знакомства, заявки, случайные диалоги.',
    action: 'Отделяет потенциальных клиентов, уточняет запрос, бюджет, формат и передаёт структурированную заявку.',
    result: 'Эксперт быстрее понимает, с кем стоит продолжать диалог.',
  },
  {
    category: 'Локальный сервис',
    situation: 'Клиенты спрашивают про стоимость, район выезда, свободное время и срочность.',
    action: 'Собирает адрес, тип задачи, удобное время и передаёт заявку мастеру.',
    result: 'Мастер получает вводные до звонка и не вытягивает всю информацию вручную.',
  },
];
---

<section id="cases" class="section">
  <div class="container">
    <div class="section-header">
      <h2>Где это особенно полезно</h2>
    </div>

    <p class="cases-note">
      Примеры ниже — учебные сценарии, которые показывают, как может работать услуга в разных нишах.
    </p>

    <div class="grid-2 anim-grid">
      {cases.map(({ category, situation, action, result }) => (
        <div class="card case-card">
          <div class="case-category">{category}</div>
          <div class="case-row">
            <div class="case-label">Ситуация</div>
            <p class="case-text">{situation}</p>
          </div>
          <div class="case-divider"></div>
          <div class="case-row">
            <div class="case-label case-label--ai">Что делает AI</div>
            <p class="case-text">{action}</p>
          </div>
          <div class="case-divider"></div>
          <div class="case-row">
            <div class="case-label case-label--result">Результат</div>
            <p class="case-text">{result}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cases-note {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-muted);
    opacity: 0.65;
    max-width: 500px;
    margin-inline: auto;
    margin-bottom: var(--space-7);
    font-style: italic;
  }

  .case-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
  }

  .case-category {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--accent-blue);
    letter-spacing: 0.01em;
  }

  .case-divider {
    height: 1px;
    background: var(--border);
  }

  .case-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .case-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .case-label--ai {
    color: var(--accent-blue);
    opacity: 0.8;
  }

  .case-label--result {
    color: var(--accent-green);
    opacity: 0.85;
  }

  .case-text {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .case-card {
      padding: var(--space-4);
      gap: var(--space-3);
    }
  }
</style>
