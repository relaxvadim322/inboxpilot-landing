---
const metrics = [
  { value: '7 дней', label: 'до запуска' },
  { value: '1 канал', label: 'на старте' },
  { value: 'Контроль у человека', label: 'AI передаёт сложные диалоги' },
  { value: 'от $490', label: 'за базовый запуск' },
];
---

<section class="section section--compact trust-strip-section">
  <div class="container">
    <div class="trust-strip">
      {metrics.map(({ value, label }, i) => (
        <>
          <div class="trust-metric">
            <span class="trust-value">{value}</span>
            <span class="trust-label">{label}</span>
          </div>
          {i < metrics.length - 1 && (
            <div class="trust-sep" aria-hidden="true"></div>
          )}
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-strip-section {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .trust-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .trust-metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-4) clamp(var(--space-6), 4vw, var(--space-9));
    text-align: center;
    flex: 1;
    min-width: 140px;
    transition: transform 200ms var(--ease-out);
  }

  .trust-metric:hover {
    transform: translateY(-1px);
  }

  .trust-metric:hover .trust-value {
    color: var(--accent-blue);
    transition: color 200ms var(--ease-out);
  }

  .trust-value {
    font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .trust-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-weight: 500;
    line-height: 1.4;
    max-width: 16ch;
  }

  .trust-sep {
    width: 1px;
    height: 36px;
    background: var(--border);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .trust-strip {
      gap: 0;
    }

    .trust-sep {
      display: none;
    }

    .trust-metric {
      min-width: 50%;
      padding: var(--space-4);
      border-bottom: 1px solid var(--border);
    }

    .trust-metric:nth-child(n+5) {
      border-bottom: none;
    }

    /* Separator inside 2×2 grid */
    .trust-metric:nth-child(odd) {
      border-right: 1px solid var(--border);
    }
  }
</style>
