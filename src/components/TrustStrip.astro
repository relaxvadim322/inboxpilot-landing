---
const items = [
  {
    icon: '⚡',
    title: 'Быстрый первый ответ',
    text: 'Клиент получает реакцию сразу, а не через несколько часов, когда интерес уже остыл.',
  },
  {
    icon: '🎯',
    title: 'Сценарий под ваш бизнес',
    text: 'Ответы, вопросы и ограничения собираются на основе ваших услуг, цен, правил и реальных переписок.',
  },
  {
    icon: '📩',
    title: 'Передача горячих заявок',
    text: 'Когда клиент готов записаться, купить или обсудить детали — заявка уходит вам или администратору.',
  },
  {
    icon: '🔒',
    title: 'Контроль остаётся у человека',
    text: 'AI не принимает критичные решения сам. В сложных ситуациях он останавливается и передаёт диалог человеку.',
  },
];
---

<section class="section section--surface">
  <div class="container">
    <p class="trust-lead anim">
      AI не заменяет вас. Он закрывает рутину до момента, где нужен человек.
    </p>

    <div class="grid-4 anim-grid">
      {items.map(({ icon, title, text }) => (
        <div class="card trust-card anim">
          <div class="icon-circle" aria-hidden="true">{icon}</div>
          <h3 class="trust-title">{title}</h3>
          <p class="trust-text">{text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-lead {
    text-align: center;
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--text-muted);
    max-width: 580px;
    margin-inline: auto;
    margin-bottom: var(--space-7);
  }

  .trust-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .trust-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text);
  }

  .trust-text {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.65;
  }
</style>
