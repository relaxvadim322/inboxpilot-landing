---
const includes = [
  'Разбор текущих входящих сообщений',
  'Карта частых вопросов',
  'Сценарий AI-ассистента',
  'База ответов под ваш бизнес',
  'Настройка правил передачи заявки',
  'Подключение к одному каналу',
  'Тестирование типовых диалогов',
  'Инструкция для владельца или администратора',
  'План улучшений после запуска',
];
---

<section class="section section--surface">
  <div class="container">
    <div class="section-header anim">
      <h2>Один понятный запуск без лишней архитектуры</h2>
      <p>
        На первом этапе не нужно строить сложную платформу. Достаточно настроить рабочий сценарий, который закрывает частые вопросы и передаёт заявки человеку.
      </p>
    </div>

    <div class="pricing-card card anim">
      <div class="pricing-header">
        <div class="pricing-name">Запуск AI-ассистента за 7 дней</div>
        <div class="pricing-price">
          <span class="pricing-from">от</span>
          <span class="pricing-amount">$490</span>
        </div>
      </div>

      <div class="pricing-divider"></div>

      <ul class="pricing-list">
        {includes.map((item) => (
          <li class="pricing-item">
            <span class="pricing-check" aria-hidden="true">✓</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>

      <div class="pricing-divider"></div>

      <div class="pricing-footer">
        <a href="#final-cta" class="btn btn-primary btn-lg pricing-cta">
          Получить разбор перед запуском
        </a>
        <p class="pricing-note">
          После разбора станет понятно, достаточно ли простого сценария или вашему бизнесу нужна более сложная интеграция.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-card {
    max-width: 600px;
    margin-inline: auto;
    background: var(--bg);
    border-color: var(--border-strong);
    padding: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .pricing-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .pricing-name {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text);
    max-width: 280px;
    line-height: 1.3;
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .pricing-from {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .pricing-amount {
    font-size: clamp(2rem, 1.5rem + 2vw, 2.75rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
  }

  .pricing-divider {
    height: 1px;
    background: var(--border);
  }

  .pricing-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pricing-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .pricing-check {
    color: var(--accent-green);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pricing-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    text-align: center;
  }

  .pricing-cta {
    width: 100%;
    max-width: 400px;
  }

  .pricing-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 420px;
    opacity: 0.75;
  }

  @media (max-width: 480px) {
    .pricing-card {
      padding: var(--space-5);
    }

    .pricing-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
