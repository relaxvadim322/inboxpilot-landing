---
const featured = [
  {
    title: 'Клиент быстрее получает первый ответ',
    text: 'AI отвечает сразу: вечером, в выходной, между задачами администратора или когда владелец занят.',
  },
  {
    title: 'Администратор меньше тратит время на рутину',
    text: 'Частые вопросы, первичные уточнения и базовая квалификация уходят в автоматический сценарий.',
  },
];

const outcomes = [
  {
    title: 'Горячие обращения становятся заметнее',
    text: 'Если клиент готов записаться или купить — такая заявка не тонет среди обычных сообщений.',
  },
  {
    title: 'Переписка становится структурной',
    text: 'Вместо хаотичных диалогов появляются понятные данные: услуга, контакт, вопрос, статус обращения.',
  },
  {
    title: 'Владелец лучше видит реальную картину',
    text: 'Становится понятно, какие вопросы повторяются, где клиенты сомневаются и что нужно улучшить в оффере.',
  },
  {
    title: 'Система улучшается на реальных диалогах',
    text: 'После запуска видно, где AI отвечает слабо, какие вопросы появляются чаще и что нужно докрутить.',
  },
];
---

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">После запуска</span>
      <h2>Что меняется после запуска</h2>
    </div>

    <div class="featured-outcomes">
      {featured.map(({ title, text }) => (
        <div class="featured-card">
          <h3 class="featured-title">{title}</h3>
          <p class="featured-text">{text}</p>
        </div>
      ))}
    </div>

    <div class="outcomes-grid">
      {outcomes.map(({ title, text }) => (
        <div class="outcome-item">
          <span class="outcome-arrow" aria-hidden="true">→</span>
          <div>
            <h3 class="outcome-title">{title}</h3>
            <p class="outcome-text">{text}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Featured outcome cards ── */
  .featured-outcomes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-5);
  }

  .featured-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-7) var(--space-6);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent-blue);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    transition:
      border-color var(--t-normal),
      box-shadow var(--t-normal);
  }

  .featured-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .featured-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .featured-text {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* ── Supporting outcomes grid ── */
  .outcomes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .outcome-item {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    padding: var(--space-5) var(--space-5);
    transition: background var(--t-fast);
  }

  .outcome-item:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .outcome-item:nth-child(-n + 2) {
    border-bottom: 1px solid var(--border);
  }

  .outcome-item:nth-child(odd) {
    border-right: 1px solid var(--border);
  }

  .outcome-arrow {
    flex-shrink: 0;
    font-size: var(--text-sm);
    color: var(--accent-blue);
    font-weight: 700;
    margin-top: 1px;
    line-height: 1.5;
    opacity: 0.8;
  }

  .outcome-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--space-2);
  }

  .outcome-text {
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .featured-outcomes {
      grid-template-columns: 1fr;
    }

    .featured-card {
      padding: var(--space-5) var(--space-4);
    }

    .featured-title {
      font-size: var(--text-lg);
    }

    .outcomes-grid {
      grid-template-columns: 1fr;
    }

    .outcome-item:nth-child(-n + 2) {
      border-bottom: none;
    }

    .outcome-item:nth-child(odd) {
      border-right: none;
    }

    .outcome-item + .outcome-item {
      border-top: 1px solid var(--border);
    }
  }
</style>
