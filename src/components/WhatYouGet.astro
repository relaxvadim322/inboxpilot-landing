---
const groups = [
  {
    label: 'Система',
    items: [
      {
        title: 'Рабочий AI-сценарий',
        text: 'Готовая логика ответов, уточняющих вопросов и передачи заявки человеку.',
      },
      {
        title: 'База ответов',
        text: 'Цены, услуги, сроки, адрес, график, условия, ограничения и частые вопросы клиентов.',
      },
      {
        title: 'Правила безопасности',
        text: 'Сценарии, где AI не должен фантазировать, принимать решение сам или давать неподходящий ответ.',
      },
    ],
  },
  {
    label: 'Команда',
    items: [
      {
        title: 'Канал передачи заявок',
        text: 'Telegram, Google Sheets, форма или простой CRM-процесс — выбираем то, что реально удобно на старте.',
      },
      {
        title: 'Инструкция',
        text: 'Как пользоваться системой, где смотреть заявки, что делать с нестандартными вопросами и как передавать диалог человеку.',
      },
      {
        title: 'Тестовые диалоги',
        text: 'Набор проверочных ситуаций, по которым можно понять, что ассистент отвечает нормально.',
      },
    ],
  },
  {
    label: 'После запуска',
    items: [
      {
        title: 'План улучшений',
        text: 'Что стоит докрутить после первых 50–100 реальных диалогов.',
      },
      {
        title: 'Простая аналитика входящих',
        text: 'Какие вопросы повторяются, где клиентам не хватает ясности и какие ответы стоит усилить.',
      },
    ],
  },
];
---

<section id="what-you-get" class="section section--surface">
  <div class="container">
    <div class="section-header">
      <h2>Что вы получаете на выходе</h2>
    </div>

    <div class="deliverables-board">
      {groups.map(({ label, items }) => (
        <div class="deliverables-group">
          <div class="deliverables-group-header">
            <span class="deliverables-group-label">{label}</span>
          </div>
          <div class="deliverables-items">
            {items.map(({ title, text }) => (
              <div class="deliverables-item">
                <span class="deliverables-dot" aria-hidden="true"></span>
                <div>
                  <h3 class="deliverables-title">{title}</h3>
                  <p class="deliverables-text">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Deliverables board ── */
  .deliverables-board {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .deliverables-group {
    display: flex;
    flex-direction: column;
  }

  .deliverables-group + .deliverables-group {
    border-left: 1px solid var(--border);
  }

  .deliverables-group-header {
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border);
  }

  .deliverables-group-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-blue);
  }

  .deliverables-items {
    display: flex;
    flex-direction: column;
  }

  .deliverables-item {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    padding: var(--space-4) var(--space-5);
    transition: background var(--t-fast);
  }

  .deliverables-item + .deliverables-item {
    border-top: 1px solid var(--border);
  }

  .deliverables-item:hover {
    background: rgba(255, 255, 255, 0.025);
  }

  .deliverables-dot {
    flex-shrink: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-blue);
    opacity: 0.65;
    margin-top: 7px;
  }

  .deliverables-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--space-2);
    line-height: 1.4;
  }

  .deliverables-text {
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .deliverables-board {
      align-items: start;
    }
  }

  @media (max-width: 768px) {
    .deliverables-board {
      grid-template-columns: 1fr;
    }

    .deliverables-group + .deliverables-group {
      border-left: none;
      border-top: 1px solid var(--border);
    }
  }
</style>
