---
const steps = [
  {
    day: 'День 1',
    title: 'Разбор входящих',
    desc: 'Вы показываете 10–30 типичных сообщений от клиентов. Мы смотрим, какие вопросы повторяются, где теряется время и какие обращения можно структурировать.',
    output: 'Список частых вопросов, точек потери заявок и сценариев для автоматизации.',
  },
  {
    day: 'День 2',
    title: 'Логика AI-ассистента',
    desc: 'Собираем сценарий: что отвечать, какие вопросы задавать, какие данные собрать и когда передавать диалог человеку.',
    output: 'Карта диалога и правила поведения ассистента.',
  },
  {
    day: 'Дни 3–5',
    title: 'Настройка системы',
    desc: 'Прописываем базу ответов, ограничения, ветки диалога и канал передачи заявок.',
    output: 'Рабочая первая версия ассистента.',
  },
  {
    day: 'День 6',
    title: 'Тестирование',
    desc: 'Прогоняем типовые ситуации: цена, запись, сложный вопрос, перенос, нестандартный запрос, недовольный клиент.',
    output: 'Список правок и улучшенная версия сценария.',
  },
  {
    day: 'День 7',
    title: 'Передача и инструкция',
    desc: 'Передаём систему, объясняем, как смотреть заявки, как обрабатывать обращения и что улучшать после первых реальных диалогов.',
    output: 'Рабочий ассистент, инструкция и план следующих улучшений.',
  },
];
---

<section id="how-it-works" class="section section--surface">
  <div class="container">
    <div class="section-header anim">
      <h2>Запуск за 7 дней без лишней разработки</h2>
      <p>
        Сначала разбираем реальные сообщения и проектируем сценарий. Только потом настраиваем ассистента. Поэтому система получается не абстрактной, а привязанной к вашему бизнесу.
      </p>
    </div>

    <div class="timeline">
      {steps.map(({ day, title, desc, output }, i) => (
        <div class="timeline-step anim">
          <div class="timeline-marker">
            <div class="step-num timeline-num" aria-label={`Шаг ${i + 1}`}>{i + 1}</div>
            {i < steps.length - 1 && <div class="timeline-line" aria-hidden="true"></div>}
          </div>
          <div class="timeline-content">
            <div class="timeline-day">{day}</div>
            <h3 class="timeline-title">{title}</h3>
            <p class="timeline-desc">{desc}</p>
            <div class="timeline-output">
              <span class="output-label">На выходе:</span> {output}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 760px;
    margin-inline: auto;
  }

  .timeline-step {
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: var(--space-5);
  }

  /* ── Left: marker ── */
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 2px;
  }

  .timeline-num {
    position: relative;
    z-index: 1;
  }

  .timeline-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, rgba(79, 140, 255, 0.4), rgba(79, 140, 255, 0.06));
    margin-block: 8px;
    border-radius: 2px;
  }

  /* ── Right: content ── */
  .timeline-content {
    padding-bottom: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .timeline-step:last-child .timeline-content {
    padding-bottom: 0;
  }

  .timeline-day {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-blue);
  }

  .timeline-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text);
  }

  .timeline-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.65;
  }

  .timeline-output {
    font-size: var(--text-sm);
    color: var(--text-muted);
    padding: var(--space-3) var(--space-4);
    background: rgba(34, 197, 94, 0.06);
    border: 1px solid rgba(34, 197, 94, 0.15);
    border-radius: var(--radius-md);
    line-height: 1.55;
  }

  .output-label {
    font-weight: 600;
    color: var(--accent-green);
  }

  @media (max-width: 480px) {
    .timeline-step {
      grid-template-columns: 40px 1fr;
      gap: var(--space-4);
    }

    .timeline-num {
      width: 30px;
      height: 30px;
      font-size: var(--text-xs);
    }
  }
</style>
