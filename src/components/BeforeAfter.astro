---
const before = [
  'Клиент ждёт ответа',
  'Администратор пишет одно и то же вручную',
  'Заявки теряются в разных каналах',
  'Владелец видит только часть картины',
  'Горячие обращения смешиваются с обычными вопросами',
  'Нет понятного сценария обработки',
];

const after = [
  'Клиент получает быстрый первый ответ',
  'AI собирает базовые данные',
  'Администратор получает уже структурированную заявку',
  'Владелец видит повторяющиеся вопросы',
  'Горячие обращения проще заметить',
  'Процесс обработки становится понятнее',
];
---

<section class="section section--surface">
  <div class="container">
    <div class="section-header">
      <h2>До InboxPilot и после</h2>
    </div>

    <div class="ba-grid">
      <!-- Before -->
      <div class="ba-col ba-before">
        <div class="ba-col-header">
          <span class="ba-label ba-label--before">До</span>
        </div>
        <ul class="ba-list">
          {before.map((item) => (
            <li class="ba-item ba-item--before">
              <span class="ba-icon" aria-hidden="true">✕</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- After -->
      <div class="ba-col ba-after">
        <div class="ba-col-header">
          <span class="ba-label ba-label--after">После</span>
        </div>
        <ul class="ba-list">
          {after.map((item) => (
            <li class="ba-item ba-item--after">
              <span class="ba-icon" aria-hidden="true">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="ba-note">
      InboxPilot не обещает «удвоить продажи за неделю». Он помогает убрать хаос из первого контакта с клиентом — и за счёт этого меньше терять тех, кто уже заинтересовался.
    </p>
  </div>
</section>

<style>
  .ba-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-7);
  }

  .ba-col {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .ba-before {
    border-top: 2px solid rgba(239, 68, 68, 0.35);
  }

  .ba-after {
    border-top: 2px solid rgba(34, 197, 94, 0.45);
  }

  .ba-col-header {
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border);
  }

  .ba-label {
    display: inline-flex;
    padding: 4px 14px;
    border-radius: 100px;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ba-label--before {
    background: rgba(239, 68, 68, 0.1);
    color: var(--accent-red);
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .ba-label--after {
    background: rgba(34, 197, 94, 0.1);
    color: var(--accent-green);
    border: 1px solid rgba(34, 197, 94, 0.2);
  }

  .ba-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: var(--space-3);
  }

  .ba-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.5;
  }

  .ba-item + .ba-item {
    border-top: 1px solid var(--border);
  }

  .ba-icon {
    flex-shrink: 0;
    font-size: 0.8rem;
    margin-top: 2px;
    font-weight: 700;
  }

  .ba-item--before .ba-icon {
    color: var(--accent-red);
    opacity: 0.7;
  }

  .ba-item--after .ba-icon {
    color: var(--accent-green);
  }

  .ba-note {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.7;
    font-style: italic;
    opacity: 0.8;
  }

  @media (max-width: 640px) {
    .ba-grid {
      grid-template-columns: 1fr;
    }

    .ba-item {
      padding: var(--space-2) var(--space-2);
    }
  }
</style>
