---
const steps = [
  {
    num: '01',
    title: 'Разбираем ваши входящие',
    text: 'Смотрим, какие вопросы чаще всего задают клиенты, где администратор тратит время и на каком этапе люди обычно пропадают.',
  },
  {
    num: '02',
    title: 'Проектируем AI-сценарий',
    text: 'Определяем, что ассистент может отвечать сам, какие вопросы должен задавать и в каких случаях обязан передать диалог человеку.',
  },
  {
    num: '03',
    title: 'Подключаем к рабочему процессу',
    text: 'Настраиваем передачу заявок в Telegram, Google Sheets, форму или простой CRM-сценарий — без лишней технической сложности.',
  },
];
---

<section id="how-it-works" class="section section--surface">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Как работает InboxPilot</span>
      <h2>Сначала разбираем входящие — потом строим ассистента под ваш бизнес</h2>
    </div>

    <div class="process-panel">
      <div class="process-steps">
        {steps.map(({ num, title, text }, i) => (
          <div class="process-step">
            <span class="process-step-num" aria-hidden="true">{num}</span>
            <h3 class="process-step-title">{title}</h3>
            <p class="process-step-text">{text}</p>
          </div>
        ))}
      </div>

      <div class="process-result">
        <span class="process-result-label">Итог</span>
        <p class="process-result-text">Клиент получает ответ быстрее, заявка попадает к человеку в собранном виде.</p>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Process panel ── */
  .process-panel {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .process-step {
    padding: var(--space-7) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: relative;
    transition: background 200ms var(--ease-out);
  }

  .process-step:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  /* Connector arrow between steps */
  .process-step + .process-step {
    border-left: 1px solid var(--border);
  }

  .process-step + .process-step::before {
    content: '→';
    position: absolute;
    left: -14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: var(--text-sm);
    color: var(--accent-blue);
    opacity: 0.5;
    font-weight: 600;
    z-index: 1;
    background: var(--bg);
    padding: 2px 4px;
    line-height: 1;
  }

  .process-step-num {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    opacity: 0.55;
  }

  .process-step-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
  }

  .process-step-text {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* ── Result strip ── */
  .process-result {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    background: rgba(34, 197, 94, 0.04);
    border-top: 1px solid var(--border);
  }

  .process-result-label {
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-green);
  }

  .process-result-text {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .process-steps {
      grid-template-columns: 1fr;
    }

    .process-step + .process-step {
      border-left: none;
      border-top: 1px solid var(--border);
    }

    .process-step + .process-step::before {
      content: '↓';
      left: 50%;
      top: -13px;
      transform: translateX(-50%);
      padding: 0 4px;
    }

    .process-step {
      padding: var(--space-5) var(--space-5);
    }

    .process-result {
      flex-direction: column;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-5);
    }
  }
</style>
