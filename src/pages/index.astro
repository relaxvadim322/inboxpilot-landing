---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Problem from '../components/Problem.astro';
import WhatWeDo from '../components/WhatWeDo.astro';
import Benefits from '../components/Benefits.astro';
import Process from '../components/Process.astro';
import WhatYouGet from '../components/WhatYouGet.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import Cases from '../components/Cases.astro';
import Pricing from '../components/Pricing.astro';
import ForWhom from '../components/ForWhom.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />
  <main>
    <Hero />
    <TrustStrip />
    <Problem />
    <WhatWeDo />
    <Benefits />
    <Process />
    <WhatYouGet />
    <BeforeAfter />
    <Cases />
    <Pricing />
    <ForWhom />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
